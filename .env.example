# APP_URL: Optional app URL for links/callback use.
APP_URL="MY_APP_URL"

# LOCAL_ML_API_URL: Preferred FastAPI base URL for the Node proxy.
# Use http://ml:8000 in Docker and http://127.0.0.1:8000 for host-local ML.
LOCAL_ML_API_URL="http://127.0.0.1:8000"

# ML_API_URL: Backward-compatible fallback variable.
ML_API_URL="http://127.0.0.1:8000"
