# APP_URL: Optional app URL for links/callback use.
APP_URL="MY_APP_URL"

# LOCAL_ML_API_URL: Local FastAPI base URL. If reachable, this is used first.
LOCAL_ML_API_URL="http://127.0.0.1:8000"

# LOCAL_ML_TIMEOUT_MS: Local model timeout before trying fallback.
LOCAL_ML_TIMEOUT_MS="1200"

# LOCAL_ML_RETRY_COOLDOWN_MS: How long to skip local retries after a local failure.
LOCAL_ML_RETRY_COOLDOWN_MS="30000"

# ML_API_URL: Fallback FastAPI URL when local model is not reachable.
# Supports either full /predict URL or base URL.
ML_API_URL="https://traffic-model-1.onrender.com/predict"

# FALLBACK_ML_TIMEOUT_MS: Hosted model timeout (allow higher for Render cold starts).
FALLBACK_ML_TIMEOUT_MS="60000"
